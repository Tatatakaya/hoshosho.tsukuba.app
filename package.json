{
  "name": "hoshosho",
  "version": "1.0.0",
  "private": true,
  "description": "ほしょしょ - 保証書管理Webアプリ",
  "scripts": {
    "dev": "wrangler dev",
    "deploy": "wrangler deploy",
    "types": "wrangler types",
    "typecheck": "tsc --noEmit",
    "db:migrate:local": "wrangler d1 migrations apply hoshosho-db --local",
    "db:migrate:remote": "wrangler d1 migrations apply hoshosho-db --remote"
  },
  "dependencies": {
    "hono": "^4.8.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "typescript": "^5.8.0",
    "wrangler": "^4.0.0"
  }
}
